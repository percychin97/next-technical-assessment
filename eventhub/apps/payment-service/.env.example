PAYMENT_SERVICE_PORT=3001
PAYMENT_SERVICE_TOKEN=payment-service-secret-token
CORE_API_WEBHOOK_URL=http://core-api/api/v1/webhooks/payments
CORE_API_WEBHOOK_SECRET=webhook-hmac-secret
DATABASE_URL=postgresql://eventhub:eventhub_password@postgres:5432/eventhub_payment

# Stripe simulator configuration
STRIPE_SUCCESS_RATE=0.9
STRIPE_CALLBACK_DELAY_MS=3000

# PayPal simulator configuration
PAYPAL_SUCCESS_RATE=0.85
PAYPAL_CALLBACK_DELAY_MS=5000

# Refund and payout failure rates (0.0 = always succeed, 1.0 = always fail)
# Use for testing failure scenarios without _fail idempotency key suffix
REFUND_FAIL_RATE=0.05
PAYOUT_FAIL_RATE=0.02

LOG_LEVEL=info
NODE_ENV=development
