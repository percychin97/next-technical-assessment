{
  "name": "eventhub-payment-service",
  "version": "1.0.0",
  "description": "EventHub Payment Microservice — Node.js 20, TypeScript, Fastify",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/helmet": "^11.1.1",
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "fastify": "^4.28.1",
    "ajv": "^8.17.1",
    "pg": "^8.12.0",
    "uuid": "^10.0.0",
    "pino": "^9.3.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "@types/pg": "^8.11.6",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "vitest": "^2.0.4",
    "@vitest/coverage-v8": "^2.0.4"
  }
}
