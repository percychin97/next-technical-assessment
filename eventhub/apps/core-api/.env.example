APP_NAME=EventHub
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC

LOG_CHANNEL=stderr
LOG_LEVEL=debug
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=eventhub_core
DB_USERNAME=eventhub
DB_PASSWORD=eventhub_password

CACHE_STORE=database
SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=database

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=eventhub
RABBITMQ_PASSWORD=eventhub_password
RABBITMQ_VHOST=/
RABBITMQ_NOTIFICATION_QUEUE=eventhub.notifications

PAYMENT_SERVICE_URL=http://payment-service:3001
PAYMENT_SERVICE_TOKEN=payment-service-secret-token
PAYMENT_WEBHOOK_SECRET=webhook-hmac-secret
PAYMENT_WEBHOOK_REPLAY_WINDOW_SECONDS=300

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1
