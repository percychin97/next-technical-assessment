RABBITMQ_URL=amqp://eventhub:eventhub_password@rabbitmq:5672
NOTIFICATION_QUEUE=eventhub.notifications
DEAD_LETTER_QUEUE=eventhub.notifications.dead_letter
DATABASE_URL=postgresql://eventhub:eventhub_password@postgres:5432/eventhub_notification
MAX_RETRY_ATTEMPTS=5
RETRY_BACKOFF_BASE_MS=1000
LOG_LEVEL=info
NODE_ENV=development
